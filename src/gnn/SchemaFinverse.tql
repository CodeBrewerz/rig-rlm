define

attribute instance_guid,
 value string;
attribute attribute_type,
 value string;
attribute string_value,
 value string;
attribute double_value,
 value double;
attribute long_value,
 value double;
attribute integer_value,
 value integer;
attribute datetime_value,
 value datetime;
attribute boolean_value,
 value boolean;
attribute is_archived,
 value boolean;
attribute av_sysOpType,
 value string;
attribute av_sysCurrentVersion,
 value integer;
attribute av_sysVersionSha,
 value integer;
attribute av_sysCurrentSha,
 value string;
attribute av_sysPreviousSha,
 value string;
attribute av_sysCurrentWorkflowSha,
 value string;
attribute av_sysPreviousWorkflowSha,
 value string;
attribute av_sysCreatedAt,
 value datetime;
attribute av_sysUpdatedAt,
 value datetime;
attribute av_sysLakefsSyncTimestamp,
 value datetime;
entity AttributeValue,
  owns attribute_type,
  owns av_sysCreatedAt,
  owns av_sysCurrentSha,
  owns av_sysCurrentVersion,
  owns av_sysCurrentWorkflowSha,
  owns av_sysLakefsSyncTimestamp,
  owns av_sysOpType,
  owns av_sysPreviousSha,
  owns av_sysPreviousWorkflowSha,
  owns av_sysUpdatedAt,
  owns av_sysVersionSha,
  owns boolean_value,
  owns datetime_value,
  owns double_value,
  owns instance_guid @key,
  owns integer_value,
  owns is_archived,
  owns long_value,
  owns string_value,
  plays HasAttribute:attribute_value;
