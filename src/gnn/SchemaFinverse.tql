fun getJurisdictionChainFromLeaf($leaf: tax-jurisdiction) -> { tax-jurisdiction, integer }:
  match
    $leaf has instance_guid $leaf_guid;
    {
      $node isa tax-jurisdiction, has instance_guid $leaf_guid, has is_archived false;
      let $depth = 0;
    } or {
      $rel isa tax-jurisdiction-parent-child, links (parent: $parent, child: $leaf), has is_archived false;
      $parent has instance_guid $parent_guid, has is_archived false;
      let $parent_node, $parent_depth in getJurisdictionChainFromLeaf($parent);
      $parent_node has instance_guid $node_guid, has is_archived false;
      $node isa tax-jurisdiction, has instance_guid $node_guid, has is_archived false;
      let $depth = $parent_depth + 1;
    };
  return { $node, $depth };
fun GetLedgerStringAttribute($owner: base-sub-ledger, $attrType: string) -> { string }:
  match
    $rel isa HasAttribute, links (owner: $owner, attribute_value: $val);
    $val has attribute_type $attrTypeL, has string_value $val_str;
    $attrTypeL == $attrType;
    let $res = $val_str;
  return { $res };
fun GetSubAccountStringAttribute($owner: sub-account, $attrType: string) -> { string }:
  match
    $rel isa HasAttribute, links (owner: $owner, attribute_value: $val);
    $val has attribute_type $attrTypeL, has string_value $val_str;
    $attrTypeL == $attrType;
    let $res = $val_str;
  return { $res };
fun GetRootLedgerStringAttribute($owner: general-ledger, $attrType: string) -> { string }:
  match
    $rel isa HasAttribute, links (owner: $owner, attribute_value: $val);
    $val has attribute_type $attrTypeL, has string_value $val_str;
    $attrTypeL == $attrType;
    let $res = $val_str;
  return { $res };
fun getTaxLedgerNamePathAndTypeTree($subledger: sub-ledger) -> { string, string, string }:
  match
  {
    (sub-ledger: $subledger, sub-account: $sub_account) isa linked-to-sub-account;

    let $sub_ledger_name = GetLedgerStringAttribute($subledger, "name");
    let $sub_ledger_abs_path = GetLedgerStringAttribute($subledger, "absolute-key-path-uid");
    let $sub_account_type = GetSubAccountStringAttribute($sub_account, "account-type");
    let $result_ledger_name = $sub_ledger_name;
    let $result_ledger_abs_path = $sub_ledger_abs_path;
    let $result_account_type = $sub_account_type;
  } or {
    (parent-non-root: $subledger, child-non-root: $nested_child_ledger) isa ledger-non-root-to-non-root;
    let $nested_ledger_name, $nested_ledger_abs_path, $nested_account_type
     in getTaxLedgerNamePathAndTypeTree($nested_child_ledger);

    let $result_ledger_name = $nested_ledger_name;
    let $result_ledger_abs_path = $nested_ledger_abs_path;
    let $result_account_type = $nested_account_type;
  };

  return { $result_ledger_name, $result_ledger_abs_path, $result_account_type };
fun getLedgerNamePathAndTypeFromRoot($root_ledger: general-ledger) -> { string, string, string }:
  match
    $root_ledger has instance_guid $root_ledger_guid, has is_archived false;
    {
      let $root_ledger_name = GetRootLedgerStringAttribute($root_ledger, "name");
      let $root_ledger_abs_path = GetRootLedgerStringAttribute($root_ledger, "absolute-key-path-uid");

      let $result_ledger_name = $root_ledger_name;
      let $result_ledger_abs_path = $root_ledger_abs_path;
      let $result_account_type = "";
    } or {
      (parent-root: $root_ledger, child-non-root: $child_ledger) isa ledger-root-to-non-root;

      let $child_ledger_name, $child_ledger_abs_path, $child_account_type
      in getTaxLedgerNamePathAndTypeTree($child_ledger);

      let $result_ledger_name = $child_ledger_name;
      let $result_ledger_abs_path = $child_ledger_abs_path;
      let $result_account_type = $child_account_type;
    };
  return { $result_ledger_name, $result_ledger_abs_path, $result_account_type };